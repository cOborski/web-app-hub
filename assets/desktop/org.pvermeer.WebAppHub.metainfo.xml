<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.pvermeer.WebAppHub</id>
  <name>Web App Hub</name>
  <developer id="org.pvermeer">
    <name>PVermeer</name>
  </developer>
  <launchable type="desktop-id">org.pvermeer.WebAppHub.desktop</launchable>
  <summary>Create web apps with ease</summary>
  <description>
    <p>
      A modern Web App Manager built with Rust, GTK, and the Adwaita design language. Web App Hub enables seamless management of web applications, each with its own icon and isolated browser profile.
    </p>
    <ul>
      <li>Seamless browser switching between all installed browsers</li>
      <li>Leverages your existing browser installations</li>
      <li>Profile isolation for enhanced privacy and organization</li>
      <li>Dedicated icons and dock indicators for each web application</li>
      <li>Extensible configuration system via YAML and desktop files</li>
    </ul>
  </description>
  <content_rating type="oars-1.1" />

  <metadata_license>CC-BY-SA-4.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>

  <url type="homepage">https://github.com/pvermeer/web-app-hub</url>
